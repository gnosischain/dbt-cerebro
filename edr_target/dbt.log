{"data": {"args": [], "base_msg": "On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.9.4\", \"profile_name\": \"elementary\", \"target_name\": \"ch_dbt\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"f9c873b5-0fa2-4fa1-a989-970569031a3c\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n    \n        with model_runs as (\n            select\n                *,\n                row_number() over (partition by unique_id order by generated_at desc) as invocations_rank_index\n            from `elementary`.`model_run_results`\n        )\n\n        select\n            unique_id,\n            invocation_id,\n            name,\n            schema_name as schema,\n            status,\n            case\n                when status != 'success' then 0\n                else round(cast(execution_time as Decimal(28, 6)), 1)\n            end as execution_time,\n            full_refresh,\n            materialization,\n            case when invocations_rank_index = 1 then compiled_code else NULL end as compiled_code,\n            generated_at\n        from model_runs\n        where coalesce(dateDiff('day', coalesce(\n        parseDateTimeBestEffortOrNull(toString(coalesce(\n        parseDateTimeBestEffortOrNull(toString(generated_at), 'UTC'),\n        toDateTime('1970-01-01 00:00:00', 'UTC')\n    )), 'UTC'),\n        toDateTime('1970-01-01 00:00:00', 'UTC')\n    ), coalesce(\n        parseDateTimeBestEffortOrNull(toString(\n    now()\n), 'UTC'),\n        toDateTime('1970-01-01 00:00:00', 'UTC')\n    )), 0)::Nullable(Int32)\n < 7\n        \n          and unique_id not like 'model.elementary.%'\n        \n        order by generated_at\n    \n\n  ...", "name": "dbt_clickhouse"}, "info": {"category": "", "code": "E001", "extra": {}, "invocation_id": "f9c873b5-0fa2-4fa1-a989-970569031a3c", "level": "debug", "msg": "dbt_clickhouse adapter: On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.9.4\", \"profile_name\": \"elementary\", \"target_name\": \"ch_dbt\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"f9c873b5-0fa2-4fa1-a989-970569031a3c\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n    \n        with model_runs as (\n            select\n                *,\n                row_number() over (partition by unique_id order by generated_at desc) as invocations_rank_index\n            from `elementary`.`model_run_results`\n        )\n\n        select\n            unique_id,\n            invocation_id,\n            name,\n            schema_name as schema,\n            status,\n            case\n                when status != 'success' then 0\n                else round(cast(execution_time as Decimal(28, 6)), 1)\n            end as execution_time,\n            full_refresh,\n            materialization,\n            case when invocations_rank_index = 1 then compiled_code else NULL end as compiled_code,\n            generated_at\n        from model_runs\n        where coalesce(dateDiff('day', coalesce(\n        parseDateTimeBestEffortOrNull(toString(coalesce(\n        parseDateTimeBestEffortOrNull(toString(generated_at), 'UTC'),\n        toDateTime('1970-01-01 00:00:00', 'UTC')\n    )), 'UTC'),\n        toDateTime('1970-01-01 00:00:00', 'UTC')\n    ), coalesce(\n        parseDateTimeBestEffortOrNull(toString(\n    now()\n), 'UTC'),\n        toDateTime('1970-01-01 00:00:00', 'UTC')\n    )), 0)::Nullable(Int32)\n < 7\n        \n          and unique_id not like 'model.elementary.%'\n        \n        order by generated_at\n    \n\n  ...", "name": "AdapterEventDebug", 