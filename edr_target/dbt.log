{"data": {"args": [], "base_msg": "On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.9.4\", \"profile_name\": \"elementary\", \"target_name\": \"ch_dbt\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"4980ae88-84d5-4449-b409-6334a0adba22\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n    \n    with ordered_run_results as (\n      select\n        *,\n        row_number() over (partition by unique_id order by run_results.generated_at desc) as row_number\n      from `elementary`.`dbt_run_results` run_results\n      join `elementary`.`dbt_models` using (unique_id)\n    ),\n\n    latest_models_invocations as (\n      select distinct invocation_id\n      from ordered_run_results\n      where row_number = 1\n    )\n\n    select\n      invocation_id,\n      command,\n      selected,\n      full_refresh,\n      \n        job_url,\n      \n      job_name,\n      job_id,\n      orchestrator\n    from `elementary`.`dbt_invocations` invocations\n    join latest_models_invocations using (invocation_id)\n  \n\n  ...", "name": "dbt_clickhouse"}, "info": {"category": "", "code": "E001", "extra": {}, "invocation_id": "4980ae88-84d5-4449-b409-6334a0adba22", "level": "debug", "msg": "dbt_clickhouse adapter: On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.9.4\", \"profile_name\": \"elementary\", \"target_name\": \"ch_dbt\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"4980ae88-84d5-4449-b409-6334a0adba22\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n    \n    with ordered_run_results as (\n      select\n        *,\n        row_number() over (partition by unique_id order by run_results.generated_at desc) as row_number\n      from `elementary`.`dbt_run_results` run_results\n      join `elementary`.`dbt_models` using (unique_id)\n    ),\n\n    latest_models_invocations as (\n      select distinct invocation_id\n      from ordered_run_results\n      where row_number = 1\n    )\n\n    select\n      invocation_id,\n      command,\n      selected,\n      full_refresh,\n      \n        job_url,\n      \n      job_name,\n      job_id,\n      orchestrator\n    from `elementary`.`dbt_invocations` invocations\n    join latest_models_invocations using (invocation_id)\n  \n\n  ...", "name": "AdapterEventDebug", "pid": 73, "thread": "MainThread", "ts": "2026-02-25T14:51:57.986658Z"}}
