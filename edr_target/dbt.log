{"data": {"args": [], "base_msg": "On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.9.4\", \"profile_name\": \"elementary\", \"target_name\": \"ch_dbt\", \"connection_name\": \"macro_log_macro_results\"} */\nselect\n      t.name as name,\n      t.database as schema,\n      multiIf(\n        engine in ('MaterializedView', 'View'), 'view',\n        engine = 'Dictionary', 'dictionary',\n        'table'\n      ) as type,\n      db.engine as db_engine,0 as is_on_cluster\n          from system.tables as t join system.databases as db on t.database = db.name\n        where schema = 'elementary'\n      \n\n  ...", "name": "dbt_clickhouse"}, "info": {"category": "", "code": "E001", "extra": {}, "invocation_id": "44badbfd-9328-46ed-89de-79e6138de24d", "level": "debug", "msg": "dbt_clickhouse adapter: On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.9.4\", \"profile_name\": \"elementary\", \"target_name\": \"ch_dbt\", \"connection_name\": \"macro_log_macro_results\"} */\nselect\n      t.name as name,\n      t.database as schema,\n      multiIf(\n        engine in ('MaterializedView', 'View'), 'view',\n        engine = 'Dictionary', 'dictionary',\n        'table'\n      ) as type,\n      db.engine as db_engine,0 as is_on_cluster\n          from system.tables as t join system.databases as db on t.database = db.name\n        where schema = 'elementary'\n      \n\n  ...", "name": "AdapterEventDebug", "pid": 73, "thread": "MainThread", "ts": "2026-02-25T14:51:55.126330Z"}}
