{"data": {"args": [], "base_msg": "On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.9.4\", \"profile_name\": \"elementary\", \"target_name\": \"ch_dbt\", \"connection_name\": \"macro_log_macro_results\"} */\nselect\n      t.name as name,\n      t.database as schema,\n      multiIf(\n        engine in ('MaterializedView', 'View'), 'view',\n        engine = 'Dictionary', 'dictionary',\n        'table'\n      ) as type,\n      db.engine as db_engine,0 as is_on_cluster\n          from system.tables as t join system.databases as db on t.database = db.name\n        where schema = 'dbt'\n      \n\n  ...", "name": "dbt_clickhouse"}, "info": {"category": "", "code": "E001", "extra": {}, "invocation_id": "c9c59a09-8449-4459-bccd-042419ef8c78", "level": "debug", "msg": "dbt_clickhouse adapter: On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.9.4\", \"profile_name\": \"elementary\", \"target_name\": \"ch_dbt\", \"connection_name\": \"macro_log_macro_results\"} */\nselect\n      t.name as name,\n      t.database as schema,\n      multiIf(\n        engine in ('MaterializedView', 'View'), 'view',\n        engine = 'Dictionary', 'dictionary',\n        'table'\n      ) as type,\n      db.engine as db_engine,0 as is_on_cluster\n          from system.tables as t join system.databases as db on t.database = db.name\n        where schema = 'dbt'\n      \n\n  ...", "name": "AdapterEventDebug", "pid": 26, "thread": "MainThread", "ts": "2026-02-25T14:41:33.415806Z"}}
